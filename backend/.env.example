# ScorCraft by HYROI Solutions — Environment Variables

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
RESUME_STORAGE_BUCKET=resumes
ORIGINAL_BUCKET=original-resumes
FORMATTED_BUCKET=formatted-resumes

# ── OpenAI (only provider) ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o

# ── AI Tuning ────────────────────────────────────────────────
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.1
CRAFT_MAX_TOKENS=4096
CRAFT_TEMPERATURE=0.1

# ── Cleanup ──────────────────────────────────────────────────
CLEANUP_AFTER_DAYS=7
CLEANUP_SECRET=your-cleanup-secret
